# Copy this file to .env and fill in real values before running docker compose.

# Strong password for the PostgreSQL database
DB_PASSWORD=changeme

# Port the app is exposed on your NAS (your reverse proxy forwards here)
APP_PORT=8080

# Password required to enable admin mode in the UI
ADMIN_PASSWORD=changeme

# Allowed CORS origin for the frontend (e.g. your Cloudflare tunnel URL).
# Defaults to '*' (dev-friendly) if not set.
CORS_ORIGIN=https://your-tunnel.trycloudflare.com
