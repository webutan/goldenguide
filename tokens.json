{
  "$schema": "https://tr.designtokens.org/format/",
  "description": "Golden Gai Map — Win2000/VA-11 Hall-A design tokens",

  "color": {
    "$type": "color",

    "chrome": {
      "bg":           { "$value": "#2a2535", "$description": "--win-bg: default window/panel background" },
      "bg-dark":      { "$value": "#1a1625", "$description": "--win-bg-dark: deeper background, insets" },
      "bg-light":     { "$value": "#3a3545", "$description": "--win-bg-light: lighter panel variant" },
      "face":         { "$value": "#2a2535", "$description": "--win-face: button face color" },
      "desktop":      { "$value": "#0a0810", "$description": "--desktop-bg: full-screen desktop background" }
    },

    "text": {
      "default":      { "$value": "#c8c0d0", "$description": "--win-text: primary readable text" },
      "disabled":     { "$value": "#605878", "$description": "--win-text-disabled: greyed-out / placeholder text" },
      "alley-label":  { "$value": "#605878", "$description": "Map alley label fill" }
    },

    "border": {
      "light":        { "$value": "#4a4060", "$description": "--win-border-light: top/left highlight in 3D border" },
      "mid":          { "$value": "#2a2535", "$description": "--win-border-mid: inner shadow" },
      "dark":         { "$value": "#1a1525", "$description": "--win-border-dark: bottom/right shadow" },
      "darkest":      { "$value": "#0d0a15", "$description": "--win-border-darkest: outermost shadow edge" }
    },

    "title-bar": {
      "active-from":  { "$value": "#c45c1a", "$description": "Active title bar gradient start (left)" },
      "active-to":    { "$value": "#e8a040", "$description": "Active title bar gradient end (right)" },
      "inactive-from":{ "$value": "#3a3040", "$description": "Inactive title bar gradient start" },
      "inactive-to":  { "$value": "#504558", "$description": "Inactive title bar gradient end" },
      "text-active":  { "$value": "#ffffff", "$description": "--win-title-text-active" },
      "text-inactive":{ "$value": "#887898", "$description": "--win-title-text-inactive" }
    },

    "selection": {
      "highlight":    { "$value": "#c45c1a", "$description": "--win-highlight: selected row / focused element" },
      "highlight-text":{ "$value": "#ffffff", "$description": "--win-highlight-text" }
    },

    "accent": {
      "pink":         { "$value": "#e94560", "$description": "--valhalla-pink" },
      "purple":       { "$value": "#4a3065", "$description": "--valhalla-purple" },
      "purple-light": { "$value": "#6a4885", "$description": "--valhalla-purple-light" },
      "orange":       { "$value": "#e8a040", "$description": "--valhalla-orange" }
    },

    "map": {
      "building-default": { "$value": "#934400", "$description": "Single-bar building fill (.has-bars)" },
      "building-hover":   { "$value": "#BD5700", "$description": "Hovered building fill" },
      "building-dimmed":  { "$value": "#1A0800", "$description": "Dimmed (tag-filtered) building fill" },
      "building-search":  { "$value": "#BD5700", "$description": "Search-highlighted building fill" }
    },

    "palette": {
      "primary": {
        "100": { "$value": "#FFA75C", "$description": "Primary orange — lightest" },
        "200": { "$value": "#FF9030" },
        "300": { "$value": "#ED6E00" },
        "400": { "$value": "#BD5700" },
        "500": { "$value": "#934400", "$description": "Primary orange — muted (used on map)" }
      },
      "amber": {
        "100": { "$value": "#FFCA5C", "$description": "Secondary amber — lightest" },
        "200": { "$value": "#FFBB30" },
        "300": { "$value": "#ED9F00" },
        "400": { "$value": "#BD7F00" },
        "500": { "$value": "#936300", "$description": "Secondary amber — muted" }
      },
      "blue": {
        "100": { "$value": "#506FBB", "$description": "Secondary blue — lightest" },
        "200": { "$value": "#3054AD" },
        "300": { "$value": "#113A9F" },
        "400": { "$value": "#0C2D7F" },
        "500": { "$value": "#072163", "$description": "Secondary blue — muted" }
      },
      "teal": {
        "100": { "$value": "#3FA8AD", "$description": "Complement teal — lightest" },
        "200": { "$value": "#1E979C" },
        "300": { "$value": "#01898F" },
        "400": { "$value": "#016D72" },
        "500": { "$value": "#005559", "$description": "Complement teal — muted (used on map floor-2 slots)" }
      }
    }
  },

  "typography": {
    "font-family": {
      "pixel-latin":    { "$type": "string", "$value": "W95FA", "$description": "Pixel-accurate MS Sans Serif (install w95fa.woff2 locally)" },
      "pixel-japanese": { "$type": "string", "$value": "PixelMplus10", "$description": "Pixel Japanese font — covers JIS kanji range" },
      "stack":          { "$type": "string", "$value": "W95FA, PixelMplus10, MS Sans Serif, Microsoft Sans Serif, sans-serif", "$description": "--win-font full stack" }
    },
    "font-size": {
      "base": { "$type": "number", "$value": 11, "$description": "--win-font-size: all UI text" }
    }
  },

  "spacing": {
    "taskbar-height": { "$type": "number", "$value": 32, "$description": "--taskbar-height" },
    "window-padding":  { "$type": "number", "$value": 2,  "$description": "Inner window content padding (from WinWindow)" },
    "icon-size":       { "$type": "number", "$value": 14, "$description": "Tag icon / small icon size" }
  },

  "effect": {
    "note": "Win98 3D borders are 4-layer box-shadows — Figma has no direct equivalent. Replicate with nested frames using border colors from the 'border' group.",
    "raised": {
      "$description": ".win-raised — outset 3D effect",
      "inset-tl-outer": { "$type": "string", "$value": "inset 1px 1px 0 {color.border.light}" },
      "inset-br-outer": { "$type": "string", "$value": "inset -1px -1px 0 {color.border.dark}" },
      "inset-tl-inner": { "$type": "string", "$value": "inset 2px 2px 0 {color.border.mid}" },
      "inset-br-inner": { "$type": "string", "$value": "inset -2px -2px 0 {color.border.darkest}" }
    },
    "sunken": {
      "$description": ".win-sunken — inset 3D effect (reversed from raised)",
      "inset-tl-outer": { "$type": "string", "$value": "inset 1px 1px 0 {color.border.dark}" },
      "inset-br-outer": { "$type": "string", "$value": "inset -1px -1px 0 {color.border.light}" },
      "inset-tl-inner": { "$type": "string", "$value": "inset 2px 2px 0 {color.border.darkest}" },
      "inset-br-inner": { "$type": "string", "$value": "inset -2px -2px 0 {color.border.mid}" }
    }
  }
}
